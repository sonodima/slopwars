{
  "name": "slopwars",
  "version": "1.0.0",
  "description": "SlopWars — AI-built multiplayer browser FPS (serverless P2P, Galacean engine)",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "pnpm --filter @slopwars/game dev",
    "editor": "pnpm --filter @slopwars/editor dev",
    "build": "pnpm --filter @slopwars/game build",
    "typecheck": "pnpm -r typecheck"
  },
  "license": "MIT",
  "devDependencies": {
    "typescript": "^6.0.3",
    "vite": "^7.0.0"
  }
}
