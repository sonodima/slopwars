{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "lib": ["ES2020", "DOM"],
    "paths": {
      "@slopwars/shared": ["../../packages/shared/src/index.ts"],
      "@game/*": ["../game/src/*"]
    }
  },
  "include": ["src", "../../packages/shared/src/virtual-modules.d.ts"]
}
